# UPLOAD_DIR = "uploads"

# APP_NAME=Wind Data Insight V2

# HOST=0.0.0.0
# PORT=8000

# DEBUG=True

# FRONTEND_URL=http://localhost:5173

# ==================================

# APPLICATION

# ==================================

APP_NAME=Wind Data Insight V2

ENVIRONMENT=development

DEBUG=True

# ==================================

# API

# ==================================

API_V1_PREFIX=/api/v1

HOST=0.0.0.0

PORT=8000

# ==================================

# FRONTEND

# ==================================

# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=http://127.0.0.1:5500

# ==================================

# DATABASE

# ==================================

DATABASE_URL=sqlite:///data/app.db

PROJECT_DATA_DIRECTORY=data/projects

# ==================================

# STORAGE

# ==================================

UPLOAD_DIRECTORY=uploads

REPORT_DIRECTORY=reports

# ==================================

# LOGGING

# ==================================

LOG_LEVEL=INFO

# ==================================

# AI

# ==================================

OLLAMA_URL=http://localhost:11434

DEFAULT_LLM=qwen3:8b

# ==================================

# FILE LIMITS

# ==================================

MAX_UPLOAD_SIZE_MB=10240

# ==================================

# FORECASTING

# ==================================

OPENWEATHER_API_KEY=

OPENWEATHER_BASE_URL=https://api.openweathermap.org

# ==================================

# PROJECT DEFAULTS

# ==================================

DEFAULT_CP_FACTOR=0.45

DEFAULT_EFFICIENCY=0.95

DEFAULT_WIND_SHEAR_ALPHA=0.143
