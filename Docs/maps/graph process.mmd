graph TB
    subgraph DataTypes["Data Types & Structures"]
        DT1["Wind Turbine Data<br/>Power/Wind Speed/Availability"]
        DT2["Time Series Data<br/>Timestamps/Values"]
        DT3["Aggregated Data<br/>Binned/Statistics"]
    end
    
    subgraph DbLayer["Database Layer"]
        DB1["SQLite Database<br/>Persistent Storage"]
        DB2["Database Manager<br/>Connection Pool"]
        DB3["Batch Processor<br/>Bulk Operations"]
        DB4["Schema Detector<br/>Structure Analysis"]
    end
    
    subgraph MemoryLayer["Memory Layer"]
        MEM1["DataManager<br/>Active DataFrame"]
        MEM2["Turbine Data Dict<br/>Per-Turbine Cache"]
        MEM3["Metadata Cache<br/>Column Info"]
    end
    
    subgraph Processing["Processing Pipeline"]
        PROC1["Load from DB"]
        PROC2["Validate Data<br/>Check NaN/Inf"]
        PROC3["Clean Data<br/>Remove Duplicates"]
        PROC4["Optimize Types<br/>Memory Efficiency"]
        PROC5["Cache Results"]
    end
    
    DT1 -->|Stored In| DB1
    DT2 -->|Stored In| DB1
    DT3 -->|Stored In| DB1
    
    DB2 -->|Manages| DB1
    DB3 -->|Processes| DB1
    DB4 -->|Analyzes| DB1
    
    PROC1 -->|Load| MEM1
    PROC2 -->|Validate| MEM1
    PROC3 -->|Clean| MEM1
    PROC4 -->|Optimize| MEM1
    PROC5 -->|Store| MEM2
    
    MEM1 -->|Metadata| MEM3