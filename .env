
# Wind Data Insight Pro (WWIP) - Environment Configuration

# ---------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------
# Path to the high-performance SQLite database
DB_PATH=data/wind_insight.db
DB_TIMEOUT=30

# ---------------------------------------------------------
# Application Metadata & Branding
# ---------------------------------------------------------
WWIP_APP_NAME=Wind Data Insight Pro
WWIP_APP_TITLE=Wind Wise Insights Pro
WWIP_APP_VERSION=1.0.0
WWIP_ORG_NAME=Tata Consulting Engineers
WWIP_ORG_DOMAIN=https://www.tataconsultingengineers.com/
WWIP_WIN_APP_ID=tce.winddatainsightpro.1.0

# ---------------------------------------------------------
# Directory & File Paths
# ---------------------------------------------------------
WWIP_JSON_CONFIG=config/config.json
WWIP_YAML_CONFIG=config/config.yaml
WWIP_LOG_DIR=logs
WWIP_DATA_DIR=data_imported
WWIP_EXPORTS_DIR=exports

# ---------------------------------------------------------
# Startup, UI & Window Settings
# ---------------------------------------------------------
WWIP_SHOW_SPLASH=True
WWIP_SPLASH_DURATION=2000
WWIP_WINDOW_WIDTH=1200
WWIP_WINDOW_HEIGHT=800
WWIP_APP_STYLE=dark
WWIP_LANGUAGE=en